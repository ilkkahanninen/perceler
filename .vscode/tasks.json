{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "make",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Watch",
            "type": "shell",
            "command": "make",
            "args": [
                "watch"
            ],
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": []
        },
        {
            "label": "Run in DOSBox-X",
            "type": "shell",
            "command": "make",
            "args": [
                "run"
            ],
            "dependsOn": "Build",
            "problemMatcher": []
        },
        {
            "label": "Disassemble current file",
            "type": "shell",
            "command": "./tools/wdis.sh",
            "args": [
                "${relativeFile}"
            ],
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true,
                "close": true
            },
            "problemMatcher": []
        }
    ]
}
